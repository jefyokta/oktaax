{
    // =========================================================================
    // Swoole-Cli v6.1 stdext — VS Code workspace settings
    // Place this file at: <project-root>/.vscode/settings.json
    // =========================================================================

    // -------------------------------------------------------------------------
    // Intelephense (bmewburn.vscode-intelephense-client)
    // Recommended: install from VS Code marketplace
    // -------------------------------------------------------------------------
    "intelephense.environment.phpVersion": "8.3",

    // Point Intelephense to the stubs directory
    // Adjust the path below to match where you placed the stubs folder
    "intelephense.environment.includePaths": [
        "./stubs/swoole-stdext"
    ],

    // Extra stubs to include (add "swoole" if you have Swoole extension)
    "intelephense.stubs": [
        "apache",
        "bcmath",
        "bz2",
        "calendar",
        "com_dotnet",
        "Core",
        "ctype",
        "curl",
        "date",
        "dba",
        "dom",
        "enchant",
        "exif",
        "FFI",
        "fileinfo",
        "filter",
        "fpm",
        "ftp",
        "gd",
        "gettext",
        "gmp",
        "hash",
        "iconv",
        "imap",
        "intl",
        "json",
        "ldap",
        "libxml",
        "mbstring",
        "meta",
        "mysqli",
        "oci8",
        "odbc",
        "openssl",
        "pcntl",
        "pcre",
        "PDO",
        "pgsql",
        "Phar",
        "posix",
        "pspell",
        "random",
        "readline",
        "Reflection",
        "session",
        "shmop",
        "SimpleXML",
        "snmp",
        "soap",
        "sockets",
        "sodium",
        "SPL",
        "sqlite3",
        "standard",
        "superglobals",
        "sysvmsg",
        "sysvsem",
        "sysvshm",
        "tidy",
        "tokenizer",
        "xml",
        "xmlreader",
        "xmlrpc",
        "xmlwriter",
        "xsl",
        "Zend OPcache",
        "zip",
        "zlib",
        "swoole"
    ],

    // Suppress "method call on non-object" for string/array primitives
    // treated as objects in Swoole-Cli stdext syntax
    "intelephense.diagnostics.undefinedMethods": false,

    // -------------------------------------------------------------------------
    // PHP CS Fixer / formatting
    // -------------------------------------------------------------------------
    "editor.formatOnSave": true,
    "[php]": {
        "editor.defaultFormatter": "bmewburn.vscode-intelephense-client",
        "editor.tabSize": 4,
        "editor.insertSpaces": true
    },

    // -------------------------------------------------------------------------
    // File associations
    // -------------------------------------------------------------------------
    "files.associations": {
        "*.php": "php"
    },

    // -------------------------------------------------------------------------
    // Optional: PHPStan / Psalm suppress for stdext syntax
    // If you use PHPStan, add the baseline or use @phpstan-ignore-next-line
    // If you use Psalm, add a custom stub path in psalm.xml
    // -------------------------------------------------------------------------
    "phpstan.enabled": false,
    "intelephense.diagnostics.exclude": [
    "**/stubs/swoole-stdext/*.php",
    "**/stubs/swoole-stdext/array.php"

],
}
